<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:drawable="clr-namespace:MauiRaider"
             x:Class="MauiRaider.DetailPage">

    <ContentPage.Resources>
        <drawable:GraphicsDrawable x:Key="drawable"  />
    </ContentPage.Resources>

    <VerticalStackLayout >
        <GraphicsView x:Name="drawableVievs" Drawable="{StaticResource drawable}  "
                      HeightRequest="250"
                      WidthRequest="250" />
        <Label x:Name="header"  FontSize="18" Margin="5" />
        <Label Text="{Binding Meseg}">
            
            
        </Label>
        <Button Text="Ok" Command="{Binding ContegCommand}"></Button>


        <Slider x:Name="slaider" Minimum ="0" Maximum="50" Value="{Binding SliderValue}" 
        MinimumTrackColor="DeepPink" MaximumTrackColor="LightPink" ThumbColor="DeepPink" />
        
        <Slider x:Name="slaider2" Minimum ="0" Maximum="50" Value="{Binding Slider2Value}" 
MinimumTrackColor="DeepPink" MaximumTrackColor="LightPink" ThumbColor="DeepPink" />
    </VerticalStackLayout>
    
</ContentPage>